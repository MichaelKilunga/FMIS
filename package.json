{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run frontend:dev\" --names=server,queue,logs,frontend --kill-others",
        "frontend:dev": "npm run dev --prefix frontend",
        "frontend:build": "npm run build --prefix frontend",
        "frontend:install": "npm install --prefix frontend --legacy-peer-deps",
        "build": "npm run frontend:build"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "tailwindcss": "^4.0.0",
        "vite": "^7.3.1"
    }
}
